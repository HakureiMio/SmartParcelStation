/dts-v1/;
#include <nordic/nrf52810_qfaa.dtsi>
#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/adc/nrf-saadc.h>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pinctrl/nrf-pinctrl.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

/ {
	model = "Smart Parcel Clip Node nRF52810 on EWT73-2G4M04S1A";
	compatible = "smartparcel,clip-node-nrf52810";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
	};

	aliases {
		watchdog0 = &wdt0;
		led-red-pwm = &led_r_pwm;
		led-green-pwm = &led_g_pwm;
		led-blue-pwm = &led_b_pwm;
		buzzer-pwm = &buzzer_pwm;
		remove-sense = &remove_sense;
		bat-adc = &zephyr_user;
		bat-div-en = &bat_div_en;
		user-btn = &user_btn;
		status-led = &status_led;
	};

	pwm_leds {
		compatible = "pwm-leds";

		led_r_pwm: led_r_pwm {
			pwms = <&pwm0 0 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
			label = "RGB red PWM on P0.11";
		};

		led_g_pwm: led_g_pwm {
			pwms = <&pwm0 1 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
			label = "RGB green PWM on P0.12";
		};

		led_b_pwm: led_b_pwm {
			pwms = <&pwm0 2 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
			label = "RGB blue PWM on P0.15";
		};

		buzzer_pwm: buzzer_pwm {
			pwms = <&pwm0 3 PWM_USEC(370) PWM_POLARITY_NORMAL>;
			label = "Passive buzzer PWM on P0.16";
		};
	};

	clip_outputs {
		compatible = "gpio-leds";

		bat_div_en: bat_div_en {
			gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
			label = "Battery divider enable on P0.20";
		};

		status_led: status_led {
			gpios = <&gpio0 22 GPIO_ACTIVE_HIGH>;
			label = "Optional status LED on P0.22";
		};
	};

	clip_inputs {
		compatible = "gpio-keys";

		remove_sense: remove_sense {
			gpios = <&gpio0 19 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Clip remove sense on P0.19";
		};

		user_btn: user_btn {
			gpios = <&gpio0 21 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Optional user button on P0.21";
		};
	};

	zephyr_user: zephyr,user {
		io-channels = <&adc 0>;
	};
};

&reg {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&adc {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,input-positive = <NRF_SAADC_AIN0>;
	};
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&pinctrl {
	pwm0_default: pwm0_default {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0, 11)>,
				<NRF_PSEL(PWM_OUT1, 0, 12)>,
				<NRF_PSEL(PWM_OUT2, 0, 15)>,
				<NRF_PSEL(PWM_OUT3, 0, 16)>;
		};
	};

	pwm0_sleep: pwm0_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0, 11)>,
				<NRF_PSEL(PWM_OUT1, 0, 12)>,
				<NRF_PSEL(PWM_OUT2, 0, 15)>,
				<NRF_PSEL(PWM_OUT3, 0, 16)>;
			low-power-enable;
		};
	};
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

&uart0 {
	status = "disabled";
};
