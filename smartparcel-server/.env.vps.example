# =============================================================================
# SmartParcel Server - VPS 部署环境变量
# =============================================================================
# 使用说明：
#   cp .env.vps.example .env
#   然后编辑 .env，将下面标注了 CHANGE-ME 的值修改为你自己的安全值。
#   切勿将 .env 提交到 Git！
#   .env 已在 .gitignore 中忽略。
# =============================================================================

# ---- 应用基础配置 ----
APP_NAME=smartparcel-server
APP_VERSION=0.1.0
API_PREFIX=/api/v1
# VPS 上必须设为 false，避免泄露调试信息
DEBUG=false

# ---- 公网访问地址 ----
# ⚠️ CHANGE-ME: 修改为你真实的 HTTPS 域名，例如 https://api.yourdomain.com
# gateway 激活后会使用这个地址作为 server 通信地址
PUBLIC_BASE_URL=https://api.example.com

# ---- MySQL 配置 ----
# ⚠️ CHANGE-ME: 修改 MYSQL_ROOT_PASSWORD、MYSQL_PASSWORD 为强密码
# MYSQL_HOST 在 Docker Compose 环境中必须保持为 mysql（服务名）
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=smartparcel
MYSQL_PASSWORD=change-this-db-password
MYSQL_DB=smartparcel
# host 部分必须是 mysql，不是 127.0.0.1
DATABASE_URL=mysql+aiomysql://smartparcel:change-this-db-password@mysql:3306/smartparcel

# ---- 安全配置 ----
DEV_AUTH_ENABLED=true
# ⚠️ CHANGE-ME: 修改为安全的 gateway 默认密钥
DEFAULT_GATEWAY_SECRET=change-this-default-gateway-secret
# HMAC 签名时间容差（秒），默认 300 秒（5分钟）
GATEWAY_SIGNATURE_TOLERANCE_SECONDS=300
# gateway 注册凭证有效期（秒），默认 600 秒（10分钟）
GATEWAY_REGISTRATION_TOKEN_TTL_SECONDS=600
GATEWAY_REGISTRATION_TOKEN_BYTES=24
GATEWAY_SECRET_BYTES=32
# ⚠️ CHANGE-ME: 修改为安全的 bootstrap token
ADMIN_BOOTSTRAP_TOKEN=change-this-admin-bootstrap-token

# ---- MQTT / EMQX 配置 ----
MQTT_ENABLED=true
# MQTT_HOST 在 Docker Compose 环境中必须保持为 emqx（服务名）
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=smartparcel-server
MQTT_KEEPALIVE=60
MQTT_TOPIC_COMMAND_TEMPLATE=server/{gateway_code}/commands
MQTT_TOPIC_EVENT_TEMPLATE=gateway/{gateway_code}/events
MQTT_TOPIC_STATUS_TEMPLATE=gateway/{gateway_code}/status
MQTT_SUBSCRIBE_ALL=true

# ---- EMQX Dashboard 配置 ----
# ⚠️ CHANGE-ME: 修改为安全的 EMQX Dashboard 密码
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=change-this-emqx-password
