# App
APP_NAME=smartparcel-server
APP_VERSION=0.1.0
API_PREFIX=/api/v1
DEBUG=true

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=smartparcel
MYSQL_PASSWORD=smartparcel
MYSQL_DB=smartparcel
DATABASE_URL=mysql+aiomysql://smartparcel:smartparcel@127.0.0.1:3306/smartparcel

# Security
DEV_AUTH_ENABLED=true
DEFAULT_GATEWAY_SECRET=dev-gateway-secret-local-only
GATEWAY_SIGNATURE_TOLERANCE_SECONDS=300
GATEWAY_REGISTRATION_TOKEN_TTL_SECONDS=600
GATEWAY_REGISTRATION_TOKEN_BYTES=24
GATEWAY_SECRET_BYTES=32
ADMIN_BOOTSTRAP_TOKEN=change-me-local-only
PUBLIC_BASE_URL=https://example.com

# MQTT / EMQX
MQTT_ENABLED=true
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=smartparcel-server
MQTT_KEEPALIVE=60
MQTT_TOPIC_COMMAND_TEMPLATE=server/{gateway_code}/commands
MQTT_TOPIC_EVENT_TEMPLATE=gateway/{gateway_code}/events
MQTT_TOPIC_STATUS_TEMPLATE=gateway/{gateway_code}/status
MQTT_SUBSCRIBE_ALL=true
