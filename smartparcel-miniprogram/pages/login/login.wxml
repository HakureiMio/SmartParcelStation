<view class="login-page {{accent}}">
  <view class="login-card">
    <view class="login-title">{{title}}</view>
    <view class="login-subtitle">欢迎使用智能快递站，请登录后继续。</view>
    <view class="form-label">账号</view>
    <input class="login-input" value="{{username}}" bindinput="inputUsername" placeholder="请输入账号" />
    <view class="form-label">密码</view>
    <input class="login-input" value="{{password}}" bindinput="inputPassword" password placeholder="请输入密码" />
    <view class="error" wx:if="{{error}}">{{error}}</view>
    <button class="login-button {{accent}}" loading="{{loading}}" bindtap="submit">登录</button>
    <view class="link-row"><text bindtap="forgot">忘记密码</text><text bindtap="register">注册账号</text></view>
  </view>
  <view class="demo-tip">演示账号：客户 user001 / 员工 staff001，密码均为 123456</view>
</view>
