.login-page { min-height: 100vh; padding: 150rpx 34rpx 40rpx; box-sizing: border-box; background: linear-gradient(180deg, #ffffff, #f6f9ff); }
.login-card { padding: 44rpx 34rpx; }
.login-title { font-size: 44rpx; font-weight: 800; color: #0f172a; }
.login-subtitle { margin: 14rpx 0 36rpx; color: #94a3b8; font-size: 26rpx; }
.login-input { height: 92rpx; background: rgba(248,250,252,.95); border: 1rpx solid #e5e7eb; border-radius: 28rpx; padding: 0 26rpx; box-sizing: border-box; }
.login-button { margin-top: 34rpx; height: 96rpx; min-height: 96rpx; }

