<view class="container safe"><view class="title">网关状态</view><view class="card"><view class="row"><text class="label">本地网关</text><text class="value">{{gatewayOnline ? '在线' : '未连接'}}</text></view><view class="row"><text class="label">服务器</text><text class="value">{{serverOnline ? '连接正常' : '未连接'}}</text></view><view class="row"><text class="label">当前模式</text><text class="value">{{mode}}</text></view><view class="hint">最近检查：{{checkedAt}}</view></view><button class="btn btn-primary" bindtap="check">重新检查</button></view>
