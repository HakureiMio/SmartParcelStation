<view class="container"><view class="title">NFC 快速取件</view><button class="btn btn-warn" bindtap="read">读取智能寻物标签 NFC</button><textarea class="input" placeholder="NFC 不可用时，手动输入 JSON 或 sps://tag?..." bindinput="input" value="{{raw}}"></textarea><view class="card"><view class="subtitle mono">{{parsedText}}</view></view><button class="btn btn-primary" bindtap="confirmServer">确认快速取件（server）</button><button class="btn" bindtap="confirmGateway">本地网关确认</button><view class="card mono">{{resultText}}</view><view class="source">数据来源：{{source}}</view></view>
