<view class="page safe"><view class="title">NFC 标签</view><view class="glass-card"><view class="row"><text class="label">NFC 能力</text><text class="value">{{available.available ? '可用' : '不可用'}}</text></view><view class="hint">{{available.reason}}</view></view><view class="glass-card"><view class="section-title">标签内容</view><view class="form-label">标签 ID</view><input class="input" data-key="tag_id" value="{{payload.tag_id}}" bindinput="input" placeholder="如 TAG001"/><view class="form-label">NFC ID</view><input class="input" data-key="tag_nfc_id" value="{{payload.tag_nfc_id}}" bindinput="input" placeholder="如 NFC_TAG_001"/><view class="notice">即将写入：{{summaryText}}</view><button class="glass-button secondary-button" bindtap="read">读取 NFC</button><button class="glass-button staff-button" bindtap="write">确认写入标签</button>
</view><view class="success" wx:if="{{resultText}}">{{resultText}}</view><view class="dev-toggle" bindtap="toggleDev">开发信息 {{devOpen ? '收起' : '展开'}}</view><view class="glass-card dev-box" wx:if="{{devOpen}}"><text>{{devPayload}}</text></view></view>
