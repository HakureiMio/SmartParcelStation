<view class="container"><view class="title">NFC 读取/写入标签</view><view class="card">可用性：{{available.available ? '可用' : '不可用'}}｜{{available.reason}}</view><input class="input" data-key="tag_id" value="{{payload.tag_id}}" bindinput="input" placeholder="tag_id"/><input class="input" data-key="tag_nfc_id" value="{{payload.tag_nfc_id}}" bindinput="input" placeholder="tag_nfc_id"/><view class="card mono">即将写入：
{{payloadText}}</view><button class="btn" bindtap="read">读取 NFC</button><button class="btn btn-warn" bindtap="write">确认写入标签</button><button class="btn" bindtap="mock">mock NFC</button><view class="card mono">{{resultText}}</view></view>
