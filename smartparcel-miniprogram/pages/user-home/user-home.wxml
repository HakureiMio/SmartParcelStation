<view class="container"><view class="card"><view class="title">用户端首页</view><view class="row"><text class="label">用户 ID</text><text class="value">{{userId}}</text></view><view class="row"><text class="label">站点 ID</text><text class="value">{{stationId}}</text></view><view class="row"><text class="label">待取包裹</text><text class="value">{{parcels.length}}</text></view><view class="row"><text class="label">最新通知</text><text class="value">{{noticeCount}}</text></view></view><view class="card" wx:if="{{hint}}"><view class="badge">{{hint.color_display_name || hint.session_color}}</view><view class="subtitle">{{hint.display_text}}</view><view>货架：{{shelvesText}}</view></view><button class="btn btn-primary" data-page="user-parcels" bindtap="go">查看待取包裹</button><button class="btn btn-primary" data-page="user-pickup-status" bindtap="go">查看取件状态</button><button class="btn btn-primary" data-page="user-notifications" bindtap="go">查看通知</button><button class="btn btn-primary" data-page="user-nfc-fast-pickup" bindtap="go">NFC 快速取件</button><button class="btn" bindtap="refresh">刷新 server 数据</button><button class="btn" bindtap="readGateway">尝试读取本地 gateway 提示</button><view class="source">数据来源：{{source}}</view></view>
