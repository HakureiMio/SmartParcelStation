<view class="container safe"><view class="card"><view class="title">欢迎回来，{{displayName}}</view><view class="subtitle">站点 {{stationId}} · 今日取件助手已准备好</view></view><view class="card"><view class="row"><text class="label">待取包裹</text><text class="value">{{parcels.length}} 件</text></view><view class="row"><text class="label">最新通知</text><text class="value">{{noticeCount}} 条</text></view><view class="notice" wx:if="{{hint}}"><view class="section-title">本次取件提示</view><view>{{hint.color_display_name || '蓝色'}}闪烁 / {{shelvesText}}</view><view class="hint">{{hint.display_text}}</view></view><view class="hint" wx:if="{{updatedText}}">{{updatedText}}</view></view><view class="action-list"><button class="btn btn-primary" data-page="user-parcels" bindtap="go">查看待取包裹</button><button class="btn btn-primary" data-page="user-pickup-status" bindtap="go">查看取件状态</button><button class="btn btn-ghost" data-page="user-notifications" bindtap="go">查看通知</button><button class="btn btn-ghost" data-page="user-nfc-fast-pickup" bindtap="go">NFC 快速取件</button><button class="btn btn-ghost" bindtap="readGateway">获取门禁取件提示</button><button class="btn btn-ghost" bindtap="logout">退出登录</button></view></view>
