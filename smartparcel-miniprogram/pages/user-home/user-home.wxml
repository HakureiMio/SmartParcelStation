<view class="page safe user-page">
  <view class="section-title">用户服务</view>
  <view class="grid"><button class="mini-action" bindtap="goGate">门禁认证</button><button class="mini-action" bindtap="goCards">我的门禁卡</button><button class="mini-action" bindtap="goParcels">待取包裹</button><button class="mini-action" bindtap="goNfc">NFC 确认取件</button></view>
  <input class="search-bar" value="{{searchText}}" bindinput="onSearch" placeholder="搜索快递编号" />
  <view class="glass-card pickup-hint" wx:if="{{hint}}">
    <view class="section-title">取件提示</view>
    <view class="hint-main">{{hint.display_text}}</view>
    <view class="hint-sub">货架：{{shelvesText}}</view>
  </view>
  <view class="section-title list-title">待取包裹</view>
  <view class="parcel-card" wx:for="{{filteredParcels}}" wx:key="parcel_code">
    <view class="parcel-top">
      <view class="parcel-code">{{item.parcel_code}}</view>
      <view class="status-pill">{{item.statusText}}</view>
    </view>
    <view class="parcel-info-row"><text>货架号</text><text>{{item.shelf_code || '待分配'}}</text></view>
    <view class="parcel-info-row"><text>标签灯光</text><view class="color-value"><view class="color-dot {{item.colorClass}}"></view><text>{{item.colorName}}</text></view></view>
    <button class="mini-action" data-code="{{item.parcel_code}}" bindtap="goNfc">NFC 确认</button>
  </view>
  <view class="glass-card empty-card" wx:if="{{filteredParcels.length === 0}}">未找到待取包裹</view>
</view>
