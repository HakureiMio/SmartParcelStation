.user-page { padding-top: 34rpx; }
.pickup-hint { margin-top: 28rpx; }
.hint-main { font-size: 30rpx; font-weight: 700; color: #1d4ed8; line-height: 1.6; }
.hint-sub { margin-top: 10rpx; color: #64748b; font-size: 25rpx; }
.list-title { margin-top: 34rpx; }
.parcel-top { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 24rpx; }
.parcel-code { font-size: 34rpx; font-weight: 800; color: #0f172a; }
.parcel-info-row { display: flex; align-items: center; justify-content: space-between; color: #64748b; font-size: 27rpx; margin: 16rpx 0; }
.parcel-info-row > text:last-child { color: #111827; font-weight: 700; }
.color-value { display: flex; align-items: center; color: #111827; font-weight: 700; }
.mini-action { height: 72rpx; min-height: 72rpx; line-height: 1.2; margin: 24rpx 0 0; border-radius: 24rpx; background: rgba(239,246,255,.96); color: #2563eb; font-weight: 700; font-size: 26rpx; }
.empty-card { color: #64748b; text-align: center; }
