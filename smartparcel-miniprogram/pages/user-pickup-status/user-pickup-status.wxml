<view class="container"><view class="title">取件状态</view><view class="card"><view wx:for="{{steps}}" wx:key="*this"><text class="badge {{item === status.step ? 'badge-green' : ''}}">{{item}}</text></view></view><view class="card" wx:if="{{status.gateway_hint}}"><view class="title">门禁提示</view><view>{{status.gateway_hint.display_text}}</view><view>数量：{{status.gateway_hint.pickup_count}}</view><view>颜色：{{status.gateway_hint.color_display_name}}</view><view>货架：{{shelvesText}}</view></view><view class="source">数据来源：{{source}}</view></view>
