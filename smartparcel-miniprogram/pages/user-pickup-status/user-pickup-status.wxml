<view class="container safe"><view class="title">取件状态</view><view class="card"><view class="section-title">流程进度</view><view wx:for="{{steps}}" wx:key="*this"><text class="badge {{item === status.step ? 'badge-green' : ''}}">{{item}}</text></view></view><view class="card" wx:if="{{status.gateway_hint}}"><view class="section-title">门禁提示</view><view class="notice">{{status.gateway_hint.display_text}}</view><view class="row"><text class="label">待取数量</text><text class="value">{{status.gateway_hint.pickup_count}} 件</text></view><view class="row"><text class="label">提示颜色</text><text class="value">{{status.gateway_hint.color_display_name}}</text></view><view class="row"><text class="label">货架位置</text><text class="value">{{shelvesText}}</text></view></view></view>
