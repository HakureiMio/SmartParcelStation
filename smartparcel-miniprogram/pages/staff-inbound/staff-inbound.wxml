<view class="container"><view class="title">入库登记</view><input class="input" data-key="parcelCode" value="{{form.parcelCode}}" bindinput="input" placeholder="包裹编号 parcel_code"/><input class="input" data-key="receiverPhone" value="{{form.receiverPhone}}" bindinput="input" placeholder="收件人手机号 receiver_phone"/><input class="input" data-key="pickupCode" value="{{form.pickupCode}}" bindinput="input" placeholder="取件码 pickup_code"/><input class="input" data-key="receiverUserId" value="{{form.receiverUserId}}" bindinput="input" placeholder="收件用户 ID receiver_user_id"/><input class="input" data-key="receiverNameMasked" value="{{form.receiverNameMasked}}" bindinput="input" placeholder="收件人脱敏名 receiver_name_masked"/><input class="input" data-key="shelfCode" value="{{form.shelfCode}}" bindinput="input" placeholder="货架号 shelf_code"/><button class="btn btn-staff" bindtap="submit">提交到 gateway</button><view class="card mono">{{resultText}}</view><view class="source">数据来源：{{source}}</view></view>
