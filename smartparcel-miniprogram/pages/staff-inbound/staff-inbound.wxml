<view class="container safe"><view class="title">入库登记</view><view class="card"><view class="form-label">包裹编号</view><input class="input" data-key="parcelCode" value="{{form.parcelCode}}" bindinput="input" placeholder="请输入包裹编号"/><view class="form-label">收件人手机号</view><input class="input" data-key="receiverPhone" value="{{form.receiverPhone}}" bindinput="input" placeholder="请输入手机号"/><view class="form-label">取件码</view><input class="input" data-key="pickupCode" value="{{form.pickupCode}}" bindinput="input" placeholder="请输入取件码"/><view class="form-label">收件用户 ID</view><input class="input" data-key="receiverUserId" value="{{form.receiverUserId}}" bindinput="input" placeholder="请输入用户 ID"/><view class="form-label">收件人脱敏名</view><input class="input" data-key="receiverNameMasked" value="{{form.receiverNameMasked}}" bindinput="input" placeholder="如 张*"/><view class="form-label">货架号</view><input class="input" data-key="shelfCode" value="{{form.shelfCode}}" bindinput="input" placeholder="如 A03"/><button class="btn btn-staff" bindtap="submit">提交入库</button></view><view class="success" wx:if="{{resultText}}">{{resultText}}</view></view>
