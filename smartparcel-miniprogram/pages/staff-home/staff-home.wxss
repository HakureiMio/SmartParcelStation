.staff-page { padding-bottom: 60rpx; }
.status-card { margin-top: 28rpx; }
.action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22rpx; margin-top: 26rpx; }
.work-card { min-height: 190rpx; padding: 28rpx; border-radius: 36rpx; background: rgba(255,255,255,.82); border: 1rpx solid rgba(226,232,240,.76); box-shadow: 0 18rpx 46rpx rgba(15,23,42,.07); box-sizing: border-box; }
.work-card.primary { background: linear-gradient(135deg, rgba(236,253,245,.94), rgba(224,242,254,.94)); }
.work-title { font-size: 30rpx; font-weight: 800; color: #0f172a; line-height: 1.3; }
.work-sub { margin-top: 14rpx; color: #64748b; font-size: 23rpx; line-height: 1.5; }
.logout { margin-top: 34rpx; }

.gateway-status-ok { color: #166534; }
.gateway-status-warn { color: #b45309; }
.gateway-status-offline { color: #b91c1c; }
