.landing-page { min-height: 100vh; position: relative; overflow: hidden; background: #ffffff; }
.brand-block { position: absolute; left: 0; right: 0; top: 34%; transform: translateY(-50%); text-align: center; z-index: 2; }
.brand-name { font-size: 64rpx; line-height: 1.1; font-weight: 820; color: #0f172a; letter-spacing: -1.2rpx; }
.brand-cn { margin-top: 16rpx; font-size: 38rpx; font-weight: 680; color: #1e293b; }
.brand-subtitle { margin-top: 18rpx; font-size: 26rpx; color: #94a3b8; letter-spacing: .6rpx; }
.bottom-actions { position: fixed; left: 36rpx; right: 36rpx; bottom: calc(34rpx + env(safe-area-inset-bottom)); display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 22rpx; z-index: 3; }
.landing-button { height: 104rpx; min-height: 104rpx; line-height: 1.2; border-radius: 36rpx; font-size: 29rpx; font-weight: 760; margin: 0; padding: 0; box-sizing: border-box; box-shadow: 0 18rpx 42rpx rgba(15,23,42,.08); }
.landing-button.staff { background: rgba(255,255,255,.92); color: #0f172a; border: 1rpx solid #dbeafe; }
.landing-button.client { background: linear-gradient(135deg, #93c5fd, #60a5fa); color: #fff; border: 1rpx solid rgba(147,197,253,.6); }
.particle { position: absolute; width: 12rpx; height: 12rpx; border-radius: 50%; background: rgba(147,197,253,.28); animation: float 5.5s ease-in-out infinite alternate; }
.p1{left:12%;top:12%;animation-delay:.2s}.p2{left:80%;top:14%;width:18rpx;height:18rpx;animation-delay:.6s}.p3{left:25%;top:48%;background:rgba(203,213,225,.32);animation-delay:1.1s}.p4{left:72%;top:42%;animation-delay:1.6s}.p5{left:16%;top:72%;width:10rpx;height:10rpx;animation-delay:2.1s}.p6{left:84%;top:70%;background:rgba(203,213,225,.30);animation-delay:.9s}.p7{left:48%;top:18%;width:9rpx;height:9rpx;animation-delay:1.8s}.p8{left:54%;top:82%;width:14rpx;height:14rpx;animation-delay:2.4s}
@keyframes float { from { transform: translateY(0); opacity: .22; } to { transform: translateY(-28rpx); opacity: .55; } }
