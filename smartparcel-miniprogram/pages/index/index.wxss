.landing { min-height: 100vh; position: relative; overflow: hidden; background: linear-gradient(180deg, #ffffff 0%, #f6f9ff 100%); padding: 88rpx 40rpx 48rpx; box-sizing: border-box; }
.hero { position: relative; z-index: 2; margin-top: 80rpx; text-align: center; }
.logo-mark { width: 116rpx; height: 116rpx; margin: 0 auto 28rpx; border-radius: 34rpx; line-height: 116rpx; color: #fff; font-size: 58rpx; font-weight: 800; background: linear-gradient(135deg, #60a5fa, #2563eb); box-shadow: 0 22rpx 48rpx rgba(37,99,235,.22); }
.hero-title { font-size: 54rpx; font-weight: 800; letter-spacing: -1rpx; color: #0f172a; }
.hero-subtitle { margin-top: 18rpx; color: #64748b; font-size: 27rpx; }
.entry-card { position: relative; z-index: 2; margin-top: 150rpx; padding: 34rpx; border-radius: 36rpx; background: rgba(255,255,255,.86); box-shadow: 0 24rpx 70rpx rgba(15,23,42,.10); border: 1rpx solid rgba(219,234,254,.9); }
.entry-title { font-size: 30rpx; font-weight: 700; margin-bottom: 22rpx; color: #1f2937; }
.entry-button { height: 104rpx; line-height: 104rpx; border-radius: 28rpx; font-weight: 700; margin-top: 22rpx; }
.entry-button.client { background: linear-gradient(135deg, #7dd3fc, #3b82f6); color: #fff; box-shadow: 0 16rpx 32rpx rgba(59,130,246,.22); }
.entry-button.staff { background: #fff; color: #0f172a; border: 1rpx solid #bfdbfe; box-shadow: 0 12rpx 28rpx rgba(15,23,42,.07); }
.particle { position: absolute; width: 14rpx; height: 14rpx; border-radius: 50%; background: rgba(147,197,253,.7); animation: float 4.8s ease-in-out infinite alternate; }
.p1{left:12%;top:12%;animation-delay:.1s}.p2{left:82%;top:10%;width:18rpx;height:18rpx;animation-delay:.5s}.p3{left:24%;top:26%;background:rgba(203,213,225,.7);animation-delay:.9s}.p4{left:72%;top:30%;animation-delay:1.2s}.p5{left:10%;top:48%;width:10rpx;height:10rpx;animation-delay:.3s}.p6{left:88%;top:54%;background:rgba(203,213,225,.8);animation-delay:1.7s}.p7{left:18%;top:72%;animation-delay:2s}.p8{left:76%;top:76%;width:20rpx;height:20rpx;animation-delay:.7s}.p9{left:48%;top:14%;width:10rpx;height:10rpx;animation-delay:1.4s}.p10{left:56%;top:62%;background:rgba(191,219,254,.8);animation-delay:2.2s}.p11{left:36%;top:86%;width:12rpx;height:12rpx;animation-delay:1.1s}.p12{left:64%;top:44%;width:10rpx;height:10rpx;animation-delay:1.9s}
@keyframes float { from { transform: translateY(0); opacity:.35 } to { transform: translateY(-28rpx); opacity:.9 } }
