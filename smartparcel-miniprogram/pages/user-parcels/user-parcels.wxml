<view class="container safe"><view class="title">待取包裹</view><view class="card" wx:for="{{parcels}}" wx:key="parcel_code"><view class="section-title">{{item.parcel_code}}</view><view class="row"><text class="label">取件货架</text><text class="value">{{item.shelf_code}}</text></view><view class="row"><text class="label">取件方式</text><text class="value">{{item.nfc_fast_pickup ? '支持 NFC 快取' : '普通取件'}}</text></view><view class="row"><text class="label">提示颜色</text><text class="value">{{item.tag_color}}</text></view><view class="hint">收件人 {{item.receiver_name_masked}}，手机 {{item.receiver_phone}}</view></view><view class="card" wx:if="{{parcels.length === 0}}"><view class="subtitle">当前没有待取包裹。</view></view></view>
