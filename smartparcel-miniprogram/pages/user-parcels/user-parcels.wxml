<view class="page safe"><view class="section-title">我的包裹</view><view class="parcel-card" wx:for="{{parcels}}" wx:key="parcel_code"><view class="parcel-code">{{item.parcel_code}}</view><view class="parcel-info-row"><text>货架号</text><text>{{item.shelf_code || item.shelf || '待分配'}}</text></view><view class="parcel-info-row"><text>取件码</text><text>{{item.pickup_code || '-'}}</text></view><view class="parcel-info-row"><text>标签编号</text><text>{{item.tag_id || '-'}}</text></view><view class="parcel-info-row"><text>状态</text><text>{{item.statusText}}</text></view><button class="btn btn-primary" wx:if="{{item.status === 'WAITING_PICKUP'}}" data-id="{{item.parcel_id || item.id}}" loading="{{confirmingId === (item.parcel_id || item.id)}}" bindtap="confirmPickup">确认已取件</button></view><view class="glass-card" wx:if="{{parcels.length === 0}}">当前没有包裹</view></view>
