<view class="page safe"><view class="section-title">待取包裹</view><view class="parcel-card" wx:for="{{parcels}}" wx:key="parcel_code"><view class="parcel-code">{{item.parcel_code}}</view><view class="parcel-info-row"><text>货架号</text><text>{{item.shelf_code || '待分配'}}</text></view><view class="parcel-info-row"><text>标签灯光</text><view class="color-value"><view class="color-dot"></view><text>{{item.colorName}}</text></view></view><view class="parcel-info-row"><text>取件状态</text><text>{{item.statusText}}</text></view></view><view class="glass-card" wx:if="{{parcels.length === 0}}">当前没有待取包裹</view></view>
