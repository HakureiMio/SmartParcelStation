<view class="container"><view class="title">待取包裹</view><view class="card" wx:for="{{parcels}}" wx:key="parcel_code"><view class="row"><text class="label">包裹编号</text><text class="value">{{item.parcel_code}}</text></view><view class="row"><text class="label">状态</text><text class="value">{{item.status}}</text></view><view class="row"><text class="label">货架</text><text class="value">{{item.shelf_code}}</text></view><view class="row"><text class="label">NFC 快取</text><text class="value">{{item.nfc_fast_pickup ? '支持' : '不支持'}}</text></view><view class="row"><text class="label">标签颜色</text><text class="value">{{item.tag_color}}</text></view><view class="subtitle">收件人：{{item.receiver_name_masked}}｜手机：{{item.receiver_phone}}</view></view><view class="source">数据来源：{{source}}</view></view>
