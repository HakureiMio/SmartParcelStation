<view class="container safe"><view class="title">通知</view><view class="card" wx:for="{{notifications}}" wx:key="id"><view class="badge">{{item.type}}</view><view class="section-title">{{item.title}}</view><view class="subtitle">{{item.content}}</view><view class="hint">{{item.time}}</view></view><view class="card" wx:if="{{notifications.length === 0}}"><view class="subtitle">暂无通知。</view></view></view>
