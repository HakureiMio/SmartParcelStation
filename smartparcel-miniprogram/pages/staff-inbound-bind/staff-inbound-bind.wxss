.inbound-bind-page { padding-bottom: 60rpx; }
.step-bar { display: flex; align-items: center; margin: 34rpx 0 28rpx; }
.step-dot { width: 52rpx; height: 52rpx; border-radius: 50%; line-height: 52rpx; text-align: center; background: #e2e8f0; color: #64748b; font-weight: 800; }
.step-dot.active { background: #60a5fa; color: #fff; box-shadow: 0 10rpx 24rpx rgba(96,165,250,.22); }
.step-line { flex: 1; height: 4rpx; background: #e2e8f0; margin: 0 12rpx; border-radius: 999rpx; }
.step-line.active { background: #93c5fd; }
.summary-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid rgba(226,232,240,.8); color: #64748b; }
.summary-row text:last-child { color: #0f172a; font-weight: 760; }
.inbound-bind-page .grid .glass-button { height: 96rpx; min-height: 96rpx; font-size: 25rpx; line-height: 1.25; }
