<view class="page safe inbound-bind-page"><view class="title">入库并绑定标签</view><view class="subtitle">按步骤完成包裹入库、读取标签和绑定确认</view><view class="step-bar"><view class="step-dot {{step >= 1 ? 'active' : ''}}">1</view><view class="step-line {{step >= 2 ? 'active' : ''}}"></view><view class="step-dot {{step >= 2 ? 'active' : ''}}">2</view><view class="step-line {{step >= 3 ? 'active' : ''}}"></view><view class="step-dot {{step >= 3 ? 'active' : ''}}">3</view></view><view class="glass-card" wx:if="{{step === 1}}"><view class="section-title">包裹入库信息</view><view class="form-label">包裹编号</view><input class="input" data-key="parcelCode" value="{{parcel.parcelCode}}" bindinput="inputParcel" placeholder="请输入包裹编号"/><view class="form-label">收件人手机号</view><input class="input" data-key="receiverPhone" value="{{parcel.receiverPhone}}" bindinput="inputParcel" placeholder="请输入手机号"/><view class="form-label">取件码</view><input class="input" data-key="pickupCode" value="{{parcel.pickupCode}}" bindinput="inputParcel" placeholder="请输入取件码"/><view class="form-label">用户 ID</view><input class="input" data-key="receiverUserId" value="{{parcel.receiverUserId}}" bindinput="inputParcel" placeholder="请输入用户 ID"/><view class="form-label">收件人脱敏名</view><input class="input" data-key="receiverNameMasked" value="{{parcel.receiverNameMasked}}" bindinput="inputParcel" placeholder="如 张*"/><view class="form-label">货架号</view><input class="input" data-key="shelfCode" value="{{parcel.shelfCode}}" bindinput="inputParcel" placeholder="如 A03"/><button class="glass-button primary-button" bindtap="nextToTag">下一步：读取标签</button></view><view class="glass-card" wx:if="{{step === 2}}"><view class="section-title">读取智能寻物标签</view><view class="notice">{{readText}}</view><button class="glass-button secondary-button" bindtap="readTag">读取 NFC 标签</button><view class="form-label">标签 ID</view><input class="input" data-key="tagId" value="{{tag.tagId}}" bindinput="inputTag" placeholder="请输入或读取标签 ID"/><view class="form-label">NFC 标签 ID</view><input class="input" data-key="tagNfcId" value="{{tag.tagNfcId}}" bindinput="inputTag" placeholder="请输入或读取 NFC 标签 ID"/><view class="grid"><button class="glass-button secondary-button" bindtap="prev">上一步</button><button class="glass-button primary-button" bindtap="nextToConfirm">下一步：确认绑定</button></view></view><view class="glass-card" wx:if="{{step === 3}}"><view class="section-title">确认入库并绑定</view><view class="summary-row"><text>包裹</text><text>{{parcel.parcelCode}}</text></view><view class="summary-row"><text>货架</text><text>{{parcel.shelfCode}}</text></view><view class="summary-row"><text>标签</text><text>{{tag.tagId}}</text></view><view class="summary-row"><text>NFC</text><text>{{tag.tagNfcId}}</text></view><view class="grid"><button class="glass-button secondary-button" bindtap="prev">上一步</button><button class="glass-button staff-button" loading="{{submitting}}" bindtap="confirm">确认入库并绑定</button></view></view><view class="success" wx:if="{{resultText}}">{{resultText}}</view></view>
