.staff-page { padding-bottom: 80rpx; }

/* Progress */
.progress-bar {
  height: 10rpx;
  background: #e2e8f0;
  border-radius: 999rpx;
  margin: 24rpx 0 10rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2dd4bf, #0ea5e9);
  border-radius: 999rpx;
  transition: width 0.35s ease;
}
.progress-text {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 20rpx;
}

/* Scenario selector */
.scenario-card { margin-top: 28rpx; }
.scenario-option {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: rgba(248,250,252,.9);
  text-align: center;
}
.scenario-option.active {
  border-color: #2dd4bf;
  background: rgba(236,253,245,.94);
}
.scenario-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 8rpx;
}
.scenario-desc {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}

/* Step cards */
.glass-card { margin-bottom: 24rpx; }
.glass-card .section-title { margin-bottom: 16rpx; }
.glass-card .row { margin: 14rpx 0; }
.glass-card .value { font-size: 28rpx; }

/* Navigation */
.step-nav {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.step-nav .glass-button { flex: 1; }

/* Warning notice for already-bound */
.warn-notice {
  background: rgba(255,243,205,.92);
  color: #b45309;
  border-radius: 26rpx;
  padding: 24rpx;
  margin: 18rpx 0;
  font-size: 25rpx;
  line-height: 1.6;
}

/* Debug */
.debug-toggle { margin: 28rpx 0 14rpx; color: #2563eb; font-size: 25rpx; text-align: center; }
.debug-box {
  white-space: pre-wrap;
  word-break: break-all;
  background: #0f172a;
  color: #dbeafe;
  border-radius: 22rpx;
  padding: 22rpx;
  font-size: 22rpx;
  line-height: 1.5;
}
