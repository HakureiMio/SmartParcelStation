<view class="container safe"><view class="title">异常处理</view><view class="card"><view class="form-label">标签 ID</view><input class="input" data-key="tagId" value="{{form.tagId}}" bindinput="input" placeholder="请输入标签 ID"/><picker range="{{types}}" bindchange="pickType"><view class="picker">异常类型：{{types[typeIndex]}}</view></picker><picker range="{{severities}}" bindchange="pickSeverity"><view class="picker">严重级别：{{severities[severityIndex]}}</view></picker><view class="form-label">异常说明</view><textarea class="input" data-key="message" value="{{form.message}}" bindinput="input" placeholder="请描述异常情况"></textarea><button class="btn btn-warn" bindtap="submit">提交异常</button></view><view class="success" wx:if="{{resultText}}">{{resultText}}</view></view>
