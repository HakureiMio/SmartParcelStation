<view class="container"><view class="title">异常处理</view><input class="input" data-key="tagId" value="{{form.tagId}}" bindinput="input" placeholder="标签 ID"/><picker range="{{types}}" bindchange="pickType"><view class="picker">异常类型：{{types[typeIndex]}}</view></picker><picker range="{{severities}}" bindchange="pickSeverity"><view class="picker">严重级别：{{severities[severityIndex]}}</view></picker><textarea class="input" data-key="message" value="{{form.message}}" bindinput="input" placeholder="异常说明"></textarea><button class="btn btn-warn" bindtap="submit">上报 gateway</button><view class="card mono">{{resultText}}</view><view class="source">数据来源：{{source}}</view></view>
