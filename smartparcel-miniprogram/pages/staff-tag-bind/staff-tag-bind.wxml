<view class="container"><view class="title">标签绑定包裹</view><input class="input" data-key="parcelCode" value="{{form.parcelCode}}" bindinput="input" placeholder="包裹编号"/><input class="input" data-key="tagId" value="{{form.tagId}}" bindinput="input" placeholder="tag_id"/><input class="input" data-key="tagNfcId" value="{{form.tagNfcId}}" bindinput="input" placeholder="tag_nfc_id"/><button class="btn" bindtap="read">读取/模拟标签</button><button class="btn btn-staff" bindtap="submit">提交绑定</button><view class="card mono">{{resultText}}</view><view class="source">数据来源：{{source}}</view></view>
