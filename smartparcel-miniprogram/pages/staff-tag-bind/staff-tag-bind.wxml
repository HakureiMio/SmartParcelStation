<view class="container safe"><view class="title">标签绑定</view><view class="card"><view class="form-label">包裹编号</view><input class="input" data-key="parcelCode" value="{{form.parcelCode}}" bindinput="input" placeholder="请输入包裹编号"/><view class="form-label">标签 ID</view><input class="input" data-key="tagId" value="{{form.tagId}}" bindinput="input" placeholder="请输入或读取标签 ID"/><view class="form-label">NFC ID</view><input class="input" data-key="tagNfcId" value="{{form.tagNfcId}}" bindinput="input" placeholder="请输入或读取 NFC ID"/><button class="btn btn-ghost" bindtap="read">读取标签</button><button class="btn btn-staff" bindtap="submit">提交绑定</button></view><view class="success" wx:if="{{resultText}}">{{resultText}}</view></view>
