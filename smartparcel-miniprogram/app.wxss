page { background:#f5f7fb; color:#1f2937; font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif; }
.container { padding:28rpx; }
.card { background:#fff; border-radius:20rpx; padding:28rpx; margin-bottom:24rpx; box-shadow:0 8rpx 24rpx rgba(31,41,55,.06); }
.title { font-size:40rpx; font-weight:700; margin-bottom:12rpx; }
.subtitle { color:#6b7280; font-size:26rpx; line-height:1.6; }
.row { display:flex; justify-content:space-between; gap:20rpx; margin:12rpx 0; }
.label { color:#6b7280; }
.value { font-weight:600; text-align:right; word-break:break-all; }
.grid { display:grid; grid-template-columns:1fr 1fr; gap:18rpx; }
.btn { margin:14rpx 0; border-radius:14rpx; }
.btn-primary { background:#0f6fff; color:#fff; }
.btn-staff { background:#10b981; color:#fff; }
.btn-warn { background:#f97316; color:#fff; }
.source { margin-top:20rpx; color:#64748b; font-size:24rpx; }
.badge { display:inline-block; border-radius:999rpx; padding:6rpx 16rpx; margin:6rpx; font-size:22rpx; background:#e0ecff; color:#0f4fb8; }
.badge-green { background:#dcfce7; color:#166534; }
.input,.picker { background:#f8fafc; border:1rpx solid #e5e7eb; border-radius:14rpx; padding:18rpx; margin:12rpx 0 20rpx; }
.mono { font-family:Menlo,Consolas,monospace; white-space:pre-wrap; word-break:break-all; }
