page { background: #f6f8fc; color: #111827; font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; }
.container { min-height: 100vh; padding: 32rpx; box-sizing: border-box; }
.safe { padding-top: 24rpx; }
.card { background: rgba(255,255,255,.92); border-radius: 32rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 18rpx 50rpx rgba(15,23,42,.08); border: 1rpx solid rgba(226,232,240,.8); }
.title { font-size: 44rpx; font-weight: 700; letter-spacing: -.5rpx; margin-bottom: 10rpx; }
.section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 18rpx; }
.subtitle { color: #6b7280; font-size: 26rpx; line-height: 1.7; }
.row { display: flex; justify-content: space-between; align-items: center; gap: 20rpx; margin: 16rpx 0; }
.label { color: #6b7280; font-size: 26rpx; }
.value { font-weight: 700; text-align: right; }
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.action-list { display: grid; gap: 18rpx; }
.btn { margin: 14rpx 0; border-radius: 24rpx; font-weight: 650; box-shadow: 0 12rpx 28rpx rgba(15,23,42,.08); }
.btn-primary { background: #4da3ff; color: #fff; }
.btn-staff { background: #1f7a8c; color: #fff; }
.btn-ghost { background: #fff; color: #1f2937; border: 1rpx solid #dbeafe; }
.btn-warn { background: #ff8a4c; color: #fff; }
.input { background: #f8fafc; border: 1rpx solid #e5e7eb; border-radius: 22rpx; padding: 22rpx; margin: 12rpx 0 22rpx; box-sizing: border-box; }
.picker { background: #f8fafc; border: 1rpx solid #e5e7eb; border-radius: 22rpx; padding: 22rpx; margin: 12rpx 0 22rpx; }
.badge { display: inline-block; border-radius: 999rpx; padding: 8rpx 18rpx; margin: 6rpx; font-size: 23rpx; background: #e0f2fe; color: #075985; }
.badge-green { background: #dcfce7; color: #166534; }
.hint { color: #64748b; font-size: 24rpx; line-height: 1.7; }
.notice { background: #eff6ff; color: #1d4ed8; border-radius: 22rpx; padding: 22rpx; margin: 18rpx 0; }
.success { background: #ecfdf5; color: #047857; border-radius: 22rpx; padding: 22rpx; margin: 18rpx 0; }
.error { background: #fff1f2; color: #be123c; border-radius: 22rpx; padding: 22rpx; margin: 18rpx 0; }
.link-row { display: flex; justify-content: center; gap: 48rpx; margin-top: 24rpx; color: #3b82f6; font-size: 26rpx; }
