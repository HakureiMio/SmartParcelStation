page { background: #fbfcff; color: #111827; font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; }
button { width: 100%; margin: 0; padding: 0; box-sizing: border-box; display: flex; align-items: center; justify-content: center; line-height: 1.2; text-align: center; }
button::after { border: none; }
.page { min-height: 100vh; padding: 32rpx; box-sizing: border-box; background: linear-gradient(180deg, #ffffff 0%, #f6f9ff 100%); }
.container { min-height: 100vh; padding: 32rpx; box-sizing: border-box; background: linear-gradient(180deg, #ffffff 0%, #f6f9ff 100%); }
.safe { padding-top: 24rpx; }
.safe-bottom { padding-bottom: calc(34rpx + env(safe-area-inset-bottom)); }
.glass-card, .card { background: rgba(255,255,255,.78); border-radius: 40rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 22rpx 60rpx rgba(15,23,42,.08); border: 1rpx solid rgba(226,232,240,.72); backdrop-filter: blur(18px); }
.glass-button, .btn { height: 96rpx; min-height: 96rpx; margin: 14rpx 0; border-radius: 32rpx; font-size: 29rpx; font-weight: 700; box-shadow: 0 16rpx 36rpx rgba(15,23,42,.08); border: 1rpx solid rgba(226,232,240,.7); }
.primary-button, .btn-primary { background: linear-gradient(135deg, #7dd3fc 0%, #60a5fa 55%, #3b82f6 100%); color: #fff; }
.secondary-button, .btn-ghost { background: rgba(255,255,255,.86); color: #172554; border: 1rpx solid #dbeafe; }
.staff-button, .btn-staff { background: linear-gradient(135deg, #99f6e4 0%, #2dd4bf 45%, #0f766e 100%); color: #fff; }
.warn-button, .btn-warn { background: linear-gradient(135deg, #fdba74, #fb923c); color: #fff; }
.search-bar { height: 88rpx; padding: 0 30rpx; background: rgba(255,255,255,.9); border-radius: 999rpx; border: 1rpx solid rgba(226,232,240,.9); box-shadow: 0 12rpx 34rpx rgba(15,23,42,.06); box-sizing: border-box; }
.parcel-card { background: rgba(255,255,255,.86); border-radius: 34rpx; padding: 30rpx; margin: 20rpx 0; box-shadow: 0 18rpx 48rpx rgba(15,23,42,.07); border: 1rpx solid rgba(226,232,240,.76); }
.status-pill { display: inline-flex; align-items: center; border-radius: 999rpx; padding: 8rpx 18rpx; font-size: 23rpx; background: #eef6ff; color: #1d4ed8; }
.color-dot { width: 18rpx; height: 18rpx; border-radius: 50%; display: inline-block; margin-right: 10rpx; background: #60a5fa; box-shadow: 0 0 0 8rpx rgba(96,165,250,.12); }
.color-dot.green { background: #34d399; box-shadow: 0 0 0 8rpx rgba(52,211,153,.12); }
.color-dot.orange { background: #fb923c; box-shadow: 0 0 0 8rpx rgba(251,146,60,.12); }
.color-dot.gray { background: #94a3b8; box-shadow: 0 0 0 8rpx rgba(148,163,184,.12); }
.section-title { font-size: 32rpx; font-weight: 760; color: #0f172a; margin-bottom: 18rpx; }
.title { font-size: 44rpx; font-weight: 780; letter-spacing: -.5rpx; margin-bottom: 10rpx; color: #0f172a; }
.subtitle { color: #64748b; font-size: 26rpx; line-height: 1.7; }
.row { display: flex; justify-content: space-between; align-items: center; gap: 20rpx; margin: 16rpx 0; }
.label { color: #64748b; font-size: 26rpx; }
.value { font-weight: 700; text-align: right; }
.grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 20rpx; align-items: stretch; }
.grid .glass-button, .grid .btn { margin: 0; width: 100%; font-size: 26rpx; padding: 0 12rpx; }
.action-list { display: grid; gap: 18rpx; }
.input { background: rgba(248,250,252,.92); border: 1rpx solid #e5e7eb; border-radius: 26rpx; padding: 22rpx; margin: 12rpx 0 22rpx; box-sizing: border-box; }
.picker { background: rgba(248,250,252,.92); border: 1rpx solid #e5e7eb; border-radius: 26rpx; padding: 22rpx; margin: 12rpx 0 22rpx; }
.badge { display: inline-block; border-radius: 999rpx; padding: 8rpx 18rpx; margin: 6rpx; font-size: 23rpx; background: #e0f2fe; color: #075985; }
.badge-green { background: #dcfce7; color: #166534; }
.hint { color: #64748b; font-size: 24rpx; line-height: 1.7; }
.notice { background: rgba(239,246,255,.9); color: #1d4ed8; border-radius: 26rpx; padding: 24rpx; margin: 18rpx 0; }
.success { background: rgba(236,253,245,.92); color: #047857; border-radius: 26rpx; padding: 24rpx; margin: 18rpx 0; }
.error { background: rgba(255,241,242,.92); color: #be123c; border-radius: 26rpx; padding: 24rpx; margin: 18rpx 0; }
.link-row { display: flex; justify-content: center; gap: 48rpx; margin-top: 24rpx; color: #3b82f6; font-size: 26rpx; }
.form-label { color: #475569; font-size: 25rpx; margin: 20rpx 0 10rpx; }
