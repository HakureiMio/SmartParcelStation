# =============================================================================
# SmartParcel Station - Nginx 反向代理示例配置
# =============================================================================
# 使用说明：
#   1. 安装 Nginx:  sudo apt-get install nginx
#   2. 将此文件复制到 Nginx 配置目录:
#        sudo cp deploy/vps/nginx.smartparcel.conf.example /etc/nginx/sites-available/smartparcel
#   3. 修改 server_name 为你的真实域名。
#   4. 启用站点:
#        sudo ln -s /etc/nginx/sites-available/smartparcel /etc/nginx/sites-enabled/
#        sudo nginx -t
#        sudo systemctl reload nginx
#
#   配合 Certbot 获取免费 SSL 证书:
#     sudo apt-get install certbot python3-certbot-nginx
#     sudo certbot --nginx -d api.example.com
#
#   或使用 Caddy (自动 HTTPS):
#     sudo apt-get install caddy
#     echo "api.example.com { reverse_proxy 127.0.0.1:18000 }" | sudo tee /etc/caddy/Caddyfile
#     sudo systemctl reload caddy
#
# 端口暴露建议：
#   公网仅开放 80/443。
#   MySQL (3306)、EMQX Dashboard (18083)、phpMyAdmin (8080) 默认绑定 127.0.0.1，
#   不暴露公网。如需远程访问，应通过 SSH tunnel 或 VPN。
# =============================================================================

# HTTP -> HTTPS 重定向（Certbot 会自动添加此部分）
server {
    listen 80;
    listen [::]:80;
    # ⚠️ CHANGE-ME: 修改为你的真实域名
    server_name api.example.com;

    # Certbot 验证
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS 主配置
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    # ⚠️ CHANGE-ME: 修改为你的真实域名
    server_name api.example.com;

    # SSL 证书路径（Certbot 默认路径）
    # ssl_certificate     /etc/letsencrypt/live/api.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.example.com/privkey.pem;

    # 现代 SSL 配置（仅示例，Certbot 会覆盖）
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # 安全头
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options DENY;
    add_header X-XSS-Protection "1; mode=block";

    # 请求体大小限制
    client_max_body_size 1M;

    # 反代到 server
    location / {
        proxy_pass http://127.0.0.1:18000;
        proxy_http_version 1.1;

        # 转发真实客户端信息
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 30s;
        proxy_read_timeout 60s;
        proxy_send_timeout 30s;

        # WebSocket 支持（用于 MQTT over WebSocket 等场景）
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
