# Gateway identity
GATEWAY_CODE=
GATEWAY_SECRET=
GATEWAY_DEVICE_ID=
GATEWAY_SERIAL=
STATION_ID=

# Binding state
BINDING_STATUS=UNBOUND
CONFIG_VERSION=1

# Server
SERVER_BASE_URL=
PUBLIC_SERVER_BASE_URL=

# MQTT
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false

# Local database
SQLITE_PATH=./data/gateway.db

# Local API
LOCAL_API_HOST=0.0.0.0
LOCAL_API_PORT=19000
LOCAL_API_TOKEN=
LOCAL_API_TOKEN_TTL_SECONDS=3600

# Provisioning API
PROVISIONING_ENABLED=true
PROVISIONING_HOST=0.0.0.0
PROVISIONING_PORT=19000
PROVISIONING_PAIRING_CODE=
PROVISIONING_TOKEN_TTL_SECONDS=600

# Wi-Fi AP provisioning
WIFI_AP_ENABLED=true
WIFI_AP_SSID_PREFIX=SmartParcel-GW
WIFI_AP_PASSWORD=
WIFI_AP_INTERFACE=wlan0
WIFI_AP_ADDRESS=192.168.4.1
WIFI_AP_DHCP_RANGE_START=192.168.4.50
WIFI_AP_DHCP_RANGE_END=192.168.4.150

# Runtime
BLE_BACKEND=real
LOG_LEVEL=INFO
SYNC_PULL_INTERVAL_SECONDS=30
SYNC_PUSH_INTERVAL_SECONDS=15
HEARTBEAT_INTERVAL_SECONDS=20

# Development options (DO NOT enable in production)
ALLOW_DEV_HTTP=false
ALLOW_UNSAFE_DEV_AUTOREGISTER=false
# Gate reader firmware authentication (separate from local operator sessions)
GATE_READER_AUTH_ENABLED=true
GATE_READER_ID=GATE01
GATE_READER_TOKEN=change-this-reader-token
GATE_QR_TTL_SECONDS=60
GATE_AUTH_RESULT_TTL_SECONDS=15
GATE_NFC_TAG_ID=GATE-NFC-001
